# ─── Stage 1: build ──────────────────────────────────────────────────────────
FROM node:24-slim AS builder

RUN corepack enable && corepack prepare pnpm@10 --activate

WORKDIR /app

# Copy workspace manifests
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./
COPY tsconfig.base.json tsconfig.json ./

# Copy all package.json files the monorepo needs
COPY lib/db/package.json                  ./lib/db/package.json
COPY lib/api-spec/package.json            ./lib/api-spec/package.json
COPY lib/api-zod/package.json             ./lib/api-zod/package.json
COPY lib/api-client-react/package.json    ./lib/api-client-react/package.json
COPY artifacts/generator-mgmt/package.json ./artifacts/generator-mgmt/package.json

# Install deps
# --config.minimumReleaseAge=0 bypasses the 1440-min publish-age check in pnpm-workspace.yaml
RUN pnpm install --frozen-lockfile --config.minimumReleaseAge=0

# Copy source
COPY lib/ ./lib/
COPY artifacts/generator-mgmt/ ./artifacts/generator-mgmt/

# Build static site
# PORT and BASE_PATH are required by vite.config.ts at build time
ENV PORT=3000
ENV BASE_PATH=/
RUN pnpm --filter @workspace/generator-mgmt run build

# ─── Stage 2: nginx runtime ──────────────────────────────────────────────────
FROM nginx:1.27-alpine AS runtime

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Custom nginx config that:
#   - serves the React SPA
#   - proxies /api/* to the backend container
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

COPY --from=builder /app/artifacts/generator-mgmt/dist/public /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
